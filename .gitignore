local.properties
.idea/
*.iml
.cxx/
captures/

# Release signing — never commit keystores or signing credentials
*.jks
*.keystore
keystore.properties
# Local signing passwords / secrets consumed by build.sh (see README § Signing)
.env

# Local adb scratch notes — not part of the project
adb/docs/

# OS
.DS_Store
