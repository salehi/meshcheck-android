    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108">
                <item android:offset="0" android:color="#FF43A047" />
                <item android:offset="0.5" android:color="#FF2E7D32" />
                <item android:offset="1" android:color="#FF1B5E20" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
