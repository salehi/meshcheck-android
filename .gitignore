# Docker build caches (Gradle cache + Android SDK) — see build.sh / docker/
.docker-cache/

# Vendored Android command-line tools / Gradle zips — downloaded manually
docker/vendor/

# Gradle / build output
.gradle/
.kotlin/
build/
*/build/

# APKs moved here at the end of a build (see app/build.gradle.kts)
dist/

